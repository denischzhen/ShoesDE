<Window x:Class="ShoesDE.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ShoesDE"
        mc:Ignorable="d" Style="{StaticResource Windows}"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Title="Авторизация" Height="450" Width="800">
    
    <Grid>
        <Border HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel Margin="60">
                <TextBlock Text="Авторизация" Margin="60 10"/>
                <TextBox Name="LoginEnter" Margin="20 10"/>
                <PasswordBox Name="PasswordEnter" Margin="20 5"/>

                <Button Name="LogInButton" Content="Войти" Foreground="White" Click="LogInButton_Click" Margin="40 20"/>
                <TextBlock Text="Войти как гость" HorizontalAlignment="Center" FontSize="16" Foreground="Blue" MouseDown="TextBlock_MouseDown"/>

            </StackPanel>
        </Border>
    </Grid>
</Window>