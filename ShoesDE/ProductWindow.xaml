<Window x:Class="ShoesDE.ProductWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ShoesDE"
        mc:Ignorable="d" Style="{StaticResource Windows}"
        Title="Продукты" Height="800" Width="1200">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <Grid HorizontalAlignment="Left" Name="AdminPanel">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="20 0">
                <TextBlock Text="Поиск:"/>
                <TextBox Name="SearchingTextBox" Width="200" TextChanged="SearchingTextBox_TextChanged"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Margin="20 0">
                <TextBlock Text="Сортировка:"/>
                <ComboBox Name="SortingComboBox" Width="200" SelectionChanged="SortingComboBox_SelectionChanged"/>
            </StackPanel>

            <StackPanel Grid.Column="2" Margin="20 0">
                <TextBlock Text="Фильтрация:"/>
                <ComboBox Name="FilteringComboBox" Width="200" SelectionChanged="FilteringComboBox_SelectionChanged"/>
            </StackPanel>
        </Grid>

        <TextBlock Grid.Row="0" Name="FullUserName" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="20 10"/>

        <ScrollViewer Grid.Row="1">
            <ItemsControl Name="ProductList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="10" Tag="{Binding Id}" Background="{Binding Background}" MouseDown="Border_MouseDown">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Width="80" Height="80" Margin="15 0">
                                    <Image Source="{Binding Photo}"/>
                                </Border>

                                <StackPanel Grid.Column="1">
                                    <TextBlock FontWeight="SemiBold">
                                        <Run Text="{Binding Category.Name}"/>
                                        <Run Text=" | "/>
                                        <Run Text="{Binding Name}"/>
                                    </TextBlock>

                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Описание: "/>
                                        <TextBlock Text="{Binding Description}" TextWrapping="Wrap"/>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Поставщик: "/>
                                        <TextBlock Text="{Binding Provider.Name}"/>
                                    </StackPanel>
                                    
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Производитель: "/>
                                        <TextBlock Text="{Binding Producer.Name}"/>
                                    </StackPanel>
                                    
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Цена: "/>
                                        <TextBlock Text="{Binding Price, StringFormat=F2}"/>
                                        <TextBlock Text=" "/>
                                        <TextBlock Text="{Binding OldPrice, StringFormat=F2}" Foreground="Red" TextDecorations="Strikethrough"/>
                                    </StackPanel>
                                    
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Ед. измерения: "/>
                                        <TextBlock Text="{Binding Unit.Name}"/>
                                    </StackPanel>
                                    
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Количество: "/>
                                        <TextBlock Text="{Binding AmountInStock}"/>
                                    </StackPanel>
                                </StackPanel>

                                <Border Grid.Column="2">
                                    <TextBlock Text="{Binding Discount}"/>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Button Grid.Row="2" Name="LogOutButton" Content="Выйти" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="20 10" Click="LogOutButton_Click"/>
        <Button Grid.Row="2" Name="CreateButton" Content="Создать" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="20 10" Click="CreateButton_Click"/>
    </Grid>
</Window>
